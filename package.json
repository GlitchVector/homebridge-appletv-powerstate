  "license": "Apache-2.0",
  "homepage": "https://github.com/rocket-monkey/homebridge-appletv-powerstate#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rocket-monkey/homebridge-appletv-powerstate.git"
  },
  "bugs": {
    "url": "https://github.com/rocket-monkey/homebridge-appletv-powerstate/issues"
  },
  "keywords": [
    "homebridge-plugin",
    "appletv",
    "apple-tv",
    "pyatv"
  ],
  "main": "dist/index.js",
  "engines": {
    "node": "^18.20.4 || ^20.18.0 || ^22.10.0 || ^24.13.0",
