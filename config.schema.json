{
  "pluginAlias": "AppleTvPowerState",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "Apple TV Powerstate Platform"
      },
      "platform": {
        "type": "string",
        "default": "AppleTvPowerState"
      },
      "devices": {
        "title": "Devices",
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": {
              "title": "Name",
              "type": "string",
              "required": true,
              "default": "Apple TV"
            },
            "ip": {
              "title": "Apple TV IP Address",
              "type": "string",
              "required": true
            },
            "credentials": {
              "title": "Companion Credentials",
              "type": "string",
              "description": "Credentials from pyatv pairing. Use the Custom UI to pair your Apple TV."
            },
            "debounceDuration": {
              "title": "Flap-guard Duration (seconds)",
              "type": "integer",
              "default": 1,
              "minimum": 1,
              "description": "Window after a state change during which flips are suppressed to filter transient flaps"
            }
          }
        }
      }
    }
  }
}
